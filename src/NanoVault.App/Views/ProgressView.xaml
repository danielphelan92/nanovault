<UserControl x:Class="NanoVault.App.Views.ProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:NanoVault.App.Converters">

    <UserControl.Resources>
        <conv:NotNullVisibilityConverter x:Key="NotNullVisible" />
        <BooleanToVisibilityConverter x:Key="BoolVisible" />
    </UserControl.Resources>

    <Grid Margin="36,28" MaxWidth="760">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Margin="0,0,0,18"
                   Text="Backing up your music…" />

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="28">
            <StackPanel>
                <TextBlock FontSize="44" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.TextPrimary}"
                           Text="{Binding ProgressPercentText}" />

                <ProgressBar Style="{StaticResource NanoProgressBar}"
                             Margin="0,14,0,6"
                             Minimum="0" Maximum="100"
                             Value="{Binding ProgressPercent, Mode=OneWay}"
                             AutomationProperties.Name="Backup progress" />

                <TextBlock Style="{StaticResource BodyText}" Margin="0,10,0,0"
                           Text="{Binding CurrentTrackText}"
                           TextTrimming="CharacterEllipsis"
                           Visibility="{Binding CurrentTrackText, Converter={StaticResource NotNullVisible}}" />

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SecondaryText}" Text="Tracks" />
                        <TextBlock Style="{StaticResource BodyText}" FontWeight="SemiBold" Text="{Binding TracksProgressText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource SecondaryText}" Text="Copied" />
                        <TextBlock Style="{StaticResource BodyText}" FontWeight="SemiBold" Text="{Binding BytesProgressText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource SecondaryText}" Text="Speed" />
                        <TextBlock Style="{StaticResource BodyText}" FontWeight="SemiBold" Text="{Binding SpeedText}" />
                    </StackPanel>
                </Grid>

                <TextBlock Style="{StaticResource SecondaryText}" Margin="0,12,0,0"
                           Text="{Binding EtaText}"
                           Visibility="{Binding EtaText, Converter={StaticResource NotNullVisible}}" />

                <Border Background="{DynamicResource Brush.WarningSubtle}" CornerRadius="8" Padding="12,8" Margin="0,14,0,0"
                        Visibility="{Binding IsPaused, Converter={StaticResource BoolVisible}}">
                    <TextBlock Style="{StaticResource BodyText}" Foreground="{DynamicResource Brush.Warning}"
                               Text="Paused — nothing is being copied right now." />
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding PauseResumeCommand}"
                            AutomationProperties.Name="Pause or resume backup">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="&#xE769;" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                <Setter Property="Text" Value="&#xE768;" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Pause" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                <Setter Property="Text" Value="Resume" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Content="Cancel" Margin="10,0,0,0"
                            Command="{Binding CancelBackupCommand}"
                            AutomationProperties.Name="Cancel backup" />
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="2" Style="{StaticResource SecondaryText}" Margin="4,14,0,0"
                   Text="Your iPod is only being read — nothing on it is changed or deleted. Cancelling keeps everything copied so far." />
    </Grid>
</UserControl>
