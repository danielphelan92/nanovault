<UserControl x:Class="NanoVault.App.Views.TracksView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="36,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}"
                    Content="Done" Command="{Binding FinishReviewCommand}"
                    AutomationProperties.Name="Finish reviewing tracks" />
            <TextBlock Style="{StaticResource PageTitle}" Text="Choose tracks to back up" />
        </DockPanel>

        <!-- Filters -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Margin="0,0,8,0"
                         Text="{Binding Tracks.SearchText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center"
                         AutomationProperties.Name="Search tracks"
                         ToolTip="Search title, artist, or album" />
                <ComboBox Grid.Column="1" Margin="0,0,8,0"
                          ItemsSource="{Binding Tracks.Artists}"
                          SelectedItem="{Binding Tracks.SelectedArtist}"
                          AutomationProperties.Name="Filter by artist" />
                <ComboBox Grid.Column="2" Margin="0,0,8,0"
                          ItemsSource="{Binding Tracks.Albums}"
                          SelectedItem="{Binding Tracks.SelectedAlbum}"
                          AutomationProperties.Name="Filter by album" />
                <ComboBox Grid.Column="3" Margin="0,0,8,0"
                          ItemsSource="{Binding Tracks.Genres}"
                          SelectedItem="{Binding Tracks.SelectedGenre}"
                          AutomationProperties.Name="Filter by genre" />
                <ComboBox Grid.Column="4" Margin="0,0,8,0"
                          ItemsSource="{Binding Tracks.Playlists}"
                          SelectedItem="{Binding Tracks.SelectedPlaylist}"
                          AutomationProperties.Name="Filter by playlist" />
                <StackPanel Grid.Column="5" Orientation="Horizontal">
                    <Button Style="{StaticResource GhostButton}" Content="Select all"
                            Command="{Binding Tracks.SelectAllVisibleCommand}" />
                    <Button Style="{StaticResource GhostButton}" Content="None"
                            Command="{Binding Tracks.DeselectAllVisibleCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Track list (virtualised) -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="4">
            <ListView ItemsSource="{Binding Tracks.VisibleTracks}"
                      BorderThickness="0"
                      Background="Transparent"
                      Foreground="{DynamicResource Brush.TextPrimary}"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      ScrollViewer.CanContentScroll="True"
                      AutomationProperties.Name="Track list">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="44">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" Margin="0"
                                              AutomationProperties.Name="{Binding Title, StringFormat='Include {0}'}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Title" Width="240" DisplayMemberBinding="{Binding Title}" />
                        <GridViewColumn Header="Artist" Width="160" DisplayMemberBinding="{Binding Artist}" />
                        <GridViewColumn Header="Album" Width="160" DisplayMemberBinding="{Binding Album}" />
                        <GridViewColumn Header="#" Width="42" DisplayMemberBinding="{Binding TrackNumber}" />
                        <GridViewColumn Header="Length" Width="64" DisplayMemberBinding="{Binding DurationText}" />
                        <GridViewColumn Header="Format" Width="110" DisplayMemberBinding="{Binding Format}" />
                        <GridViewColumn Header="Status" Width="150" DisplayMemberBinding="{Binding StatusText}" />
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Style="{StaticResource SecondaryText}" VerticalAlignment="Center">
                <Run Text="{Binding Tracks.SelectedCount, Mode=OneWay}" /><Run Text=" of " /><Run Text="{Binding Tracks.TotalCount, Mode=OneWay}" /><Run Text=" tracks selected" />
            </TextBlock>
        </DockPanel>
    </Grid>
</UserControl>
