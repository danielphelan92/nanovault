<UserControl x:Class="NanoVault.App.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:NanoVault.App.Converters">

    <UserControl.Resources>
        <conv:EqualsVisibilityConverter x:Key="EqualsVisible" />
        <conv:NotNullVisibilityConverter x:Key="NotNullVisible" />
        <BooleanToVisibilityConverter x:Key="BoolVisible" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Focusable="False">
        <Grid Margin="36,28" MaxWidth="860">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="0,0,0,22">
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding OpenSettingsCommand}"
                        AutomationProperties.Name="Open settings"
                        ToolTip="Settings">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE713;" />
                </Button>
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="10" Background="{DynamicResource Brush.Accent}">
                        <TextBlock Text="&#xE8D6;" FontFamily="Segoe MDL2 Assets" FontSize="19"
                                   Foreground="{DynamicResource Brush.AccentForeground}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="NanoVault" FontSize="17" FontWeight="SemiBold"
                                   Foreground="{DynamicResource Brush.TextPrimary}" />
                        <TextBlock Text="Back up music from your iPod" Style="{StaticResource SecondaryText}" />
                    </StackPanel>
                </StackPanel>
            </DockPanel>

            <!-- Headline -->
            <TextBlock Grid.Row="1"
                       Style="{StaticResource PageTitle}"
                       Margin="0,0,0,18"
                       Text="Back up music from your iPod" />

            <!-- Device status card -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,14"
                    AutomationProperties.Name="iPod status">
                <Grid>
                    <!-- Searching -->
                    <StackPanel Visibility="{Binding DeviceState, Converter={StaticResource EqualsVisible}, ConverterParameter=Searching}">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Searching for an iPod…" />
                        <ProgressBar Style="{StaticResource NanoProgressBar}" IsIndeterminate="True" Margin="0,14,0,4" />
                        <TextBlock Style="{StaticResource SecondaryText}" Margin="0,8,0,0"
                                   Text="Connect your iPod with its USB cable. It will be detected automatically." />
                    </StackPanel>

                    <!-- Found -->
                    <StackPanel Visibility="{Binding DeviceState, Converter={StaticResource EqualsVisible}, ConverterParameter=Found}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource Brush.Success}" VerticalAlignment="Center" />
                            <TextBlock Style="{StaticResource SectionTitle}" Margin="8,0,0,0"
                                       Text="{Binding SelectedDevice.DisplayName, StringFormat='iPod found — {0}'}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource SecondaryText}" Margin="24,6,0,0"
                                   Text="{Binding DeviceSummary}" />
                        <StackPanel Margin="24,6,0,0" Orientation="Horizontal"
                                    Visibility="{Binding IsScanning, Converter={StaticResource BoolVisible}}">
                            <ProgressBar Style="{StaticResource NanoProgressBar}" IsIndeterminate="True" Width="120"
                                         VerticalAlignment="Center" />
                            <TextBlock Style="{StaticResource SecondaryText}" Margin="10,0,0,0"
                                       Text="{Binding ScanStatusText}" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource SecondaryText}" Margin="24,6,0,0"
                                   FontWeight="SemiBold"
                                   Text="{Binding ScanSummary}"
                                   Visibility="{Binding ScanSummary, Converter={StaticResource NotNullVisible}}" />
                    </StackPanel>

                    <!-- Multiple found -->
                    <StackPanel Visibility="{Binding DeviceState, Converter={StaticResource EqualsVisible}, ConverterParameter=MultipleFound}">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="More than one iPod found" />
                        <TextBlock Style="{StaticResource SecondaryText}" Margin="0,6,0,10"
                                   Text="Choose which iPod to back up:" />
                        <ItemsControl ItemsSource="{Binding Devices}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource SecondaryButton}" Margin="0,4,0,0"
                                            HorizontalAlignment="Left"
                                            Command="{Binding DataContext.SelectDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE955;" FontFamily="Segoe MDL2 Assets" Margin="0,0,8,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding DisplayName}" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Storage unavailable -->
                    <StackPanel Visibility="{Binding DeviceState, Converter={StaticResource EqualsVisible}, ConverterParameter=StorageUnavailable}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource Brush.Warning}" VerticalAlignment="Center" />
                            <TextBlock Style="{StaticResource SectionTitle}" Margin="8,0,0,0"
                                       Text="An iPod is connected, but its storage is unavailable" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource SecondaryText}" Margin="24,6,0,10"
                                   Text="The device may need to appear in Windows as a drive (disk use) before its music can be read. Nothing is wrong with your iPod." />
                        <StackPanel Orientation="Horizontal" Margin="24,0,0,0">
                            <Button Style="{StaticResource SecondaryButton}" Content="Show me how to fix this"
                                    Command="{Binding OpenTroubleshootingCommand}" />
                            <Button Style="{StaticResource SecondaryButton}" Content="Scan Again" Margin="8,0,0,0"
                                    Command="{Binding RefreshDevicesCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Not found -->
                    <StackPanel Visibility="{Binding DeviceState, Converter={StaticResource EqualsVisible}, ConverterParameter=NotFound}">
                        <TextBlock Style="{StaticResource SectionTitle}" Text="No iPod found" />
                        <TextBlock Style="{StaticResource SecondaryText}" Margin="0,6,0,10"
                                   Text="Connect your iPod with its USB cable and give it a few seconds. If it still does not appear, the troubleshooting guide can help." />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SecondaryButton}" Content="Scan Again"
                                    Command="{Binding RefreshDevicesCommand}" />
                            <Button Style="{StaticResource GhostButton}" Content="Troubleshooting" Margin="8,0,0,0"
                                    Command="{Binding OpenTroubleshootingCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Disconnected during backup -->
                    <StackPanel Visibility="{Binding DeviceState, Converter={StaticResource EqualsVisible}, ConverterParameter=DisconnectedDuringBackup}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource Brush.Warning}" VerticalAlignment="Center" />
                            <TextBlock Style="{StaticResource SectionTitle}" Margin="8,0,0,0"
                                       Text="The iPod was disconnected during the backup" />
                        </StackPanel>
                        <TextBlock Style="{StaticResource SecondaryText}" Margin="24,6,0,10"
                                   Text="Everything copied so far has been kept, and your iPod has not been changed. Reconnect it and back up again — finished tracks are skipped automatically." />
                        <Button Style="{StaticResource SecondaryButton}" Content="Scan Again" Margin="24,0,0,0"
                                HorizontalAlignment="Left"
                                Command="{Binding RefreshDevicesCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Destination card -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,14"
                    AutomationProperties.Name="Backup folder">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Backup folder" />
                    <DockPanel Margin="0,10,0,0">
                        <Button DockPanel.Dock="Right"
                                Style="{StaticResource SecondaryButton}"
                                Content="Choose backup folder…"
                                Margin="12,0,0,0"
                                Command="{Binding ChooseDestinationCommand}"
                                AutomationProperties.Name="Choose backup folder" />
                        <Border Background="{DynamicResource Brush.InputBackground}"
                                BorderBrush="{DynamicResource Brush.InputBorder}"
                                BorderThickness="1" CornerRadius="8" Padding="12,8">
                            <TextBlock Style="{StaticResource BodyText}"
                                       Text="{Binding DestinationFolder, TargetNullValue='No folder chosen yet'}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </DockPanel>

                    <!-- Pre-backup summary -->
                    <ItemsControl ItemsSource="{Binding PlanSummaryLines}" Margin="2,12,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                               Foreground="{DynamicResource Brush.Accent}" VerticalAlignment="Center" />
                                    <TextBlock Style="{StaticResource SecondaryText}" Margin="8,0,0,0" Text="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Background="{DynamicResource Brush.ErrorSubtle}" CornerRadius="8" Padding="12,8" Margin="0,12,0,0"
                            Visibility="{Binding FreeSpaceProblem, Converter={StaticResource NotNullVisible}}">
                        <TextBlock Style="{StaticResource BodyText}"
                                   Foreground="{DynamicResource Brush.Error}"
                                   Text="{Binding FreeSpaceProblem}" />
                    </Border>
                </StackPanel>
            </Border>

            <!-- Actions -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,4,0,24">
                <Button Style="{StaticResource PrimaryButton}"
                        Command="{Binding StartBackupCommand}"
                        AutomationProperties.Name="Back up music">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Text="Back Up Music" />
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource GhostButton}"
                        Content="Review tracks first"
                        Margin="12,0,0,0"
                        Command="{Binding ReviewTracksCommand}"
                        AutomationProperties.Name="Review tracks before backing up" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
