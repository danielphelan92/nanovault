<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.Accent">#6F5BD6</Color>

    <SolidColorBrush x:Key="Brush.WindowBackground" Color="#F5F4FA" />
    <SolidColorBrush x:Key="Brush.CardBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.CardBorder" Color="#E4E1F0" />
    <SolidColorBrush x:Key="Brush.TextPrimary" Color="#1C1B22" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="#5E5B6E" />
    <SolidColorBrush x:Key="Brush.Accent" Color="#6F5BD6" />
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#5D49C4" />
    <SolidColorBrush x:Key="Brush.AccentPressed" Color="#4E3BB8" />
    <SolidColorBrush x:Key="Brush.AccentSubtle" Color="#EEEAFB" />
    <SolidColorBrush x:Key="Brush.AccentForeground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="Brush.Success" Color="#1F7A3D" />
    <SolidColorBrush x:Key="Brush.SuccessSubtle" Color="#E4F4E9" />
    <SolidColorBrush x:Key="Brush.Warning" Color="#8A6A16" />
    <SolidColorBrush x:Key="Brush.WarningSubtle" Color="#FBF3DC" />
    <SolidColorBrush x:Key="Brush.Error" Color="#B3403C" />
    <SolidColorBrush x:Key="Brush.ErrorSubtle" Color="#FBE7E6" />
    <SolidColorBrush x:Key="Brush.InputBackground" Color="#FAFAFD" />
    <SolidColorBrush x:Key="Brush.InputBorder" Color="#CFCBE2" />
    <SolidColorBrush x:Key="Brush.ProgressTrack" Color="#E7E4F2" />
    <SolidColorBrush x:Key="Brush.RowHover" Color="#F2F0FA" />
    <SolidColorBrush x:Key="Brush.FocusVisual" Color="#1C1B22" />

</ResourceDictionary>
